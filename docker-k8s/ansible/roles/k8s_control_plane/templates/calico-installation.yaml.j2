#jinja2: trim_blocks: True, lstrip_blocks: True
# Managed by Ansible (k8s_control_plane). Tigera operator Installation custom
# resource. VXLAN encapsulation is used because the OCI VCN does not run BGP and
# drops IPIP; the pod CIDR matches kubeadm's podSubnet.
---
apiVersion: operator.tigera.io/v1
kind: Installation
metadata:
  name: default
spec:
  calicoNetwork:
    bgp: Disabled
    ipPools:
      - name: default-ipv4-ippool
        cidr: "{{ pod_network_cidr }}"
        encapsulation: "{{ calico_encapsulation }}"
        natOutgoing: Enabled
        nodeSelector: all()
---
apiVersion: operator.tigera.io/v1
kind: APIServer
metadata:
  name: default
spec: {}
