# Copy this file to inventory/hosts.yml and set ansible_host to the VM public IP.
# Get the IP from the Terraform stack:
#   cd ../terraform-linux-day1 && terraform output -raw instance_public_ip
---
kvm_hosts:
  hosts:
    linux-day1-vm:
      # Replace with the public IP from `terraform output -raw instance_public_ip`.
      ansible_host: 203.0.113.10
