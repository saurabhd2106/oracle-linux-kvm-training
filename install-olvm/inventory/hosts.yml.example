# Copy this file to inventory/hosts.yml and set ansible_host to the VM public IP.
# Get the IP from the Terraform stack:
#   cd ../linux-ol8 && terraform output -raw instance_public_ip
#
# NOTE: The OLVM 4.5 Engine requires Oracle Linux 8.8+. The ../linux-ol8 stack
# provisions Oracle Linux 8 by default. To use an existing host instead, point
# ansible_host at any reachable Oracle Linux 8 host.
---
olvm_hosts:
  hosts:
    olvm-engine:
      # Replace with the public IP from `terraform output -raw instance_public_ip`.
      ansible_host: 203.0.113.10
